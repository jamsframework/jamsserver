<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE resources PUBLIC "-//GlassFish.org//DTD GlassFish Application Server 3.1 Resource Definitions//EN" "http://glassfish.org/dtds/glassfish-resources_1_5.dtd">
<!--
  JTA datasource for the JPA persistence unit (jndi-name jdbc/jamsserver).
  Host and credentials are taken from environment variables so the same WAR
  runs unchanged in Docker; Payara expands ${ENV=...} at deploy time.
-->
<resources>
    <jdbc-connection-pool name="mysql_jamsserver_rootPool"
                          res-type="javax.sql.DataSource"
                          datasource-classname="com.mysql.cj.jdbc.MysqlDataSource"
                          connection-validation-method="auto-commit"
                          is-connection-validation-required="true"
                          steady-pool-size="8" max-pool-size="32"
                          pool-resize-quantity="2" idle-timeout-in-seconds="300"
                          max-wait-time-in-millis="60000">
        <property name="serverName" value="${ENV=MYSQL_HOST}"/>
        <property name="portNumber" value="${ENV=MYSQL_PORT}"/>
        <property name="databaseName" value="${ENV=MYSQL_DB}"/>
        <property name="user" value="${ENV=MYSQL_USER}"/>
        <property name="password" value="${ENV=MYSQL_PASSWORD}"/>
        <property name="useSSL" value="false"/>
        <property name="allowPublicKeyRetrieval" value="true"/>
        <property name="serverTimezone" value="UTC"/>
        <property name="zeroDateTimeBehavior" value="CONVERT_TO_NULL"/>
    </jdbc-connection-pool>
    <jdbc-resource enabled="true" jndi-name="jdbc/jamsserver" object-type="user" pool-name="mysql_jamsserver_rootPool"/>
</resources>
